@startuml StageFlow_UseCase_Entreprise_Admin

skinparam backgroundColor #FFFFFF
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F5F7FF
  BorderColor #4F46E5
  ArrowColor #475569
  FontColor #0F172A
  FontSize 13
}
skinparam actor {
  BorderColor #334155
  BackgroundColor #E2E8F0
  FontStyle bold
}
skinparam rectangle {
  BorderColor #4F46E5
  BackgroundColor #FAFAFF
  FontStyle bold
  FontColor #1E1B4B
}
skinparam ArrowColor #475569
skinparam nodesep 20
skinparam ranksep 45

title Diagramme de cas d'utilisation détaillé — Entreprise & Administrateur

actor "Entreprise" as Entreprise
actor "Administrateur" as Admin
actor "Service Email\n(Nodemailer)" as ServiceEmail <<system>>

rectangle "Gestion des offres et candidatures (Entreprise)" as ENT {
  usecase "Se déconnecter" as UC11c
  usecase "Publier une offre de stage" as UC37
  usecase "Modifier une offre de stage" as UC38
  usecase "Supprimer une offre de stage" as UC39
  usecase "Consulter les candidatures reçues" as UC40
  usecase "Changer le statut d'une candidature" as UC41
  usecase "Proposer un entretien" as UC42
  usecase "Mettre à jour le statut\nd'un entretien" as UC43
  usecase "Échanger des messages\navec les étudiants" as UC44
}

rectangle "Administration" as ADM {
  usecase "Se déconnecter  " as UC11a
  usecase "Consulter le tableau\nde bord statistique" as UC45
  usecase "Créer une formation" as UC46
  usecase "Modifier une formation" as UC47
  usecase "Supprimer une formation" as UC48
  usecase "Exporter la liste des\nformations (CSV / PDF)" as UC49
  usecase "Accepter une demande\nd'inscription" as UC50
  usecase "Refuser une demande\nd'inscription" as UC51
}

Entreprise --> UC11c
Entreprise --> UC37
Entreprise --> UC38
Entreprise --> UC39
Entreprise --> UC40
Entreprise --> UC41
Entreprise --> UC42
Entreprise --> UC43
Entreprise --> UC44

Admin --> UC11a
Admin --> UC45
Admin --> UC46
Admin --> UC47
Admin --> UC48
Admin --> UC49
Admin --> UC50
Admin --> UC51

UC41 ..> ServiceEmail : <<include>>
UC42 ..> ServiceEmail : <<include>>
UC43 ..> ServiceEmail : <<include>>
UC49 ..> UC47 : <<extend>>

note bottom of ENT
  <b>Fidélité au code réel :</b> ces cas d'utilisation correspondent à des
  endpoints backend réels, protégés par le rôle "entreprise". Aucune interface
  "/dashboard/company/*" n'existe encore côté frontend à ce jour.
end note

note bottom of ADM
  <b>Fidélité au code réel :</b> "Accepter/Refuser une demande" = endpoints
  admin réels et fonctionnels, mais sans page frontend dédiée (placeholder UI).
  Les sections admin "Utilisateurs", "Inscriptions", "Statistiques" (onglet
  dédié) et "Paramètres" sont des coquilles vides sans logique métier.
end note

@enduml
