@startuml StageFlow_UseCase_Etudiant

skinparam backgroundColor #FFFFFF
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F5F7FF
  BorderColor #4F46E5
  ArrowColor #475569
  FontColor #0F172A
  FontSize 12
}
skinparam actor {
  BorderColor #334155
  BackgroundColor #E2E8F0
  FontStyle bold
}
skinparam rectangle {
  BorderColor #4F46E5
  BackgroundColor #FAFAFF
  FontStyle bold
  FontColor #1E1B4B
}
skinparam ArrowColor #475569
skinparam nodesep 18
skinparam ranksep 40

title Diagramme de cas d'utilisation détaillé — Étudiant

actor "Étudiant" as Etudiant
actor "Service IA\n(Groq LLM)" as ServiceIA <<system>>

rectangle "Profil" as R1 {
  usecase "Consulter mon profil" as UC12
  usecase "Modifier mon profil" as UC13
  usecase "Gérer mon CV" as UC14
}

rectangle "Formations" as R2 {
  usecase "Faire une demande\nd'inscription" as UC15
  usecase "Suivre mes demandes\nd'inscription" as UC16
}

rectangle "Offres & candidatures" as R3 {
  usecase "Rechercher et filtrer\nles offres" as UC17
  usecase "Sauvegarder en favoris" as UC18
  usecase "Postuler à une offre" as UC19
  usecase "Suivre mes candidatures" as UC20
}

rectangle "Entretiens" as R4 {
  usecase "Consulter mes entretiens" as UC21
  usecase "Confirmer un entretien" as UC22
  usecase "Refuser un entretien" as UC23
  usecase "Consulter les modalités" as UC24
}

rectangle "Communication" as R5 {
  usecase "Consulter mes conversations" as UC25
  usecase "Envoyer un message" as UC26
  usecase "Consulter mes notifications" as UC27
  usecase "Marquer comme lues" as UC28
  usecase "Supprimer une notification" as UC29
}

rectangle "Assistant IA (SAGE)" as R6 {
  usecase "Discuter avec SAGE" as UC30
  usecase "Obtenir des recommandations\nd'offres" as UC31
  usecase "Analyser mon CV via l'IA" as UC32
  usecase "Générer une lettre\nde motivation via l'IA" as UC33
  usecase "Consulter le contexte IA" as UCctx
}

rectangle "Compte & paramètres" as R7 {
  usecase "Se déconnecter" as UC11
  usecase "Gérer mes paramètres\nde compte / sécurité" as UC34
  usecase "Gérer mes préférences" as UC35
  usecase "Supprimer mon compte" as UC36
}

Etudiant --> UC12
Etudiant --> UC13
Etudiant --> UC14
Etudiant --> UC15
Etudiant --> UC16
Etudiant --> UC17
Etudiant --> UC18
Etudiant --> UC19
Etudiant --> UC20
Etudiant --> UC21
Etudiant --> UC25
Etudiant --> UC26
Etudiant --> UC27
Etudiant --> UC30
Etudiant --> UC11
Etudiant --> UC34
Etudiant --> UC35
Etudiant --> UC36

UC18 ..> UC17 : <<extend>>
UC22 ..> UC21 : <<extend>>
UC23 ..> UC21 : <<extend>>
UC24 ..> UC21 : <<extend>>
UC28 ..> UC27 : <<extend>>
UC29 ..> UC27 : <<extend>>
UC30 ..> UCctx : <<include>>
UC31 ..> UC30 : <<extend>>
UC32 ..> UC30 : <<extend>>
UC33 ..> UC30 : <<extend>>
UC30 -- ServiceIA

@enduml
