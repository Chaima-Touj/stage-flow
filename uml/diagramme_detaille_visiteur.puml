@startuml StageFlow_UseCase_Visiteur

skinparam backgroundColor #FFFFFF
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F5F7FF
  BorderColor #4F46E5
  ArrowColor #475569
  FontColor #0F172A
  FontSize 13
}
skinparam actor {
  BorderColor #334155
  BackgroundColor #E2E8F0
  FontStyle bold
}
skinparam rectangle {
  BorderColor #4F46E5
  BackgroundColor #FAFAFF
  FontStyle bold
  FontColor #1E1B4B
}
skinparam ArrowColor #475569

title Diagramme de cas d'utilisation détaillé — Visiteur (accès public)

actor "Visiteur" as Visiteur

rectangle "Accès public (sans authentification)" {
  usecase "Consulter la page d'accueil" as UC1
  usecase "Parcourir les formations\n(catalogue public)" as UC2
  usecase "Consulter le détail d'une formation" as UC3
  usecase "Parcourir les offres de stage\n(catalogue public)" as UC4
  usecase "Consulter le détail d'une offre" as UC5
  usecase "Créer un compte\n(Étudiant ou Entreprise)" as UC6
  usecase "Vérifier son adresse email\n(code à 6 chiffres)" as UC7
  usecase "Se connecter" as UC8
  usecase "Changer la langue\n(FR / EN / AR)" as UC9
  usecase "Changer le thème\n(clair / sombre)" as UC10
}

Visiteur --> UC1
Visiteur --> UC2
Visiteur --> UC3
Visiteur --> UC4
Visiteur --> UC5
Visiteur --> UC6
Visiteur --> UC8
Visiteur --> UC9
Visiteur --> UC10

UC6 ..> UC7 : <<include>>
UC8 ..> UC7 : <<include>>

@enduml
