@startuml StageFlow_UseCase_Global

skinparam backgroundColor #FFFFFF
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F5F7FF
  BorderColor #4F46E5
  ArrowColor #475569
  FontColor #0F172A
  FontSize 13
}
skinparam actor {
  BorderColor #334155
  BackgroundColor #E2E8F0
  FontStyle bold
  FontSize 13
}
skinparam rectangle {
  BorderColor #4F46E5
  BackgroundColor #FAFAFF
  FontStyle bold
  FontColor #1E1B4B
  FontSize 14
}
skinparam ArrowColor #475569
skinparam nodesep 20
skinparam ranksep 55

title Diagramme de cas d'utilisation global — StageFlow

actor "Visiteur" as Visiteur
actor "Étudiant" as Etudiant
actor "Entreprise" as Entreprise
actor "Administrateur" as Admin
actor "Service IA\n(Groq LLM)" as ServiceIA <<system>>

rectangle "StageFlow" {

  rectangle "Accès public" as PUB {
    usecase "Consulter les pages publiques\n(accueil, formations, offres)" as UC_pub
    usecase "Créer un compte" as UC_register
    usecase "Se connecter" as UC_login
    usecase "Vérifier son adresse email" as UC_verify
    usecase "Personnaliser l'affichage\n(langue FR/EN/AR, thème)" as UC_pref
  }

  rectangle "Espace Étudiant" as ETU {
    usecase "Gérer mon profil et mon CV" as UC_profile
    usecase "Demander l'inscription\nà une formation" as UC_enrollReq
    usecase "Rechercher et postuler\naux offres de stage" as UC_apply
    usecase "Suivre mes candidatures" as UC_track
    usecase "Gérer mes entretiens" as UC_interview
    usecase "Utiliser la messagerie" as UC_msg
    usecase "Gérer mes notifications" as UC_notif
    usecase "Utiliser l'assistant IA (SAGE)" as UC_ai
    usecase "Gérer mon compte\net mes paramètres" as UC_settings
  }

  rectangle "Espace Entreprise" as ENT {
    usecase "Gérer mes offres de stage" as UC_offers
    usecase "Gérer les candidatures reçues" as UC_manageApp
    usecase "Gérer les entretiens" as UC_manageInt
  }

  rectangle "Administration" as ADM {
    usecase "Consulter le tableau\nde bord statistique" as UC_dash
    usecase "Gérer le catalogue\nde formations" as UC_formations
    usecase "Traiter les demandes\nd'inscription" as UC_reqAdmin
  }
}

Visiteur --> UC_pub
Visiteur --> UC_register
Visiteur --> UC_login
Visiteur --> UC_pref

Etudiant --> UC_profile
Etudiant --> UC_enrollReq
Etudiant --> UC_apply
Etudiant --> UC_track
Etudiant --> UC_interview
Etudiant --> UC_msg
Etudiant --> UC_notif
Etudiant --> UC_ai
Etudiant --> UC_settings

Entreprise --> UC_offers
Entreprise --> UC_manageApp
Entreprise --> UC_manageInt
Entreprise --> UC_msg

Admin --> UC_dash
Admin --> UC_formations
Admin --> UC_reqAdmin

UC_register ..> UC_verify : <<include>>
UC_login ..> UC_verify : <<include>>
UC_enrollReq ..> UC_pub : <<extend>>
UC_ai -- ServiceIA
UC_reqAdmin ..> UC_formations : <<extend>>

legend right
  |= Note |
  | Un service d'emails (Nodemailer) est également sollicité en arrière-plan par : |
  | Créer un compte, Vérifier son email, Gérer les candidatures reçues, Gérer les entretiens |
endlegend

@enduml
